<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Social Media - Post</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Barlow:wght@400;500&display=swap"
        rel="stylesheet">

    <style>
        :root {
            --val-red: #FF4655;
            --val-white: #ECE8E1;
            --val-dark: #0F1923;
            --val-mid: #1A2733;
            --val-border: rgba(255, 70, 85, 0.35);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--val-dark);
            background-image:
                repeating-linear-gradient(0deg, transparent, transparent 59px, rgba(255, 70, 85, 0.04) 60px),
                repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(255, 70, 85, 0.04) 60px);
            font-family: 'Barlow', sans-serif;
            color: var(--val-white);
            min-height: 100vh;
        }

        /* ===== NAVBAR ===== */
        nav {
            background: rgba(15, 25, 35, 0.95) !important;
            border-bottom: 1px solid var(--val-border);
            height: 56px;
            line-height: 56px;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(8px);
        }

        nav .nav-wrapper {
            background: transparent !important;
        }

        nav .brand-logo {
            font-family: 'Rajdhani', sans-serif !important;
            font-size: 1.3rem !important;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--val-white) !important;
        }

        nav .brand-logo em {
            color: var(--val-red);
            font-style: normal;
        }

        .teal {
            background-color: transparent !important;
        }

        /* ===== SECTION LABEL ===== */
        .section-label {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 16px;
            margin-top: 32px;
        }

        .section-label span {
            font-family: 'Rajdhani', sans-serif;
            font-size: 13px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--val-red);
            white-space: nowrap;
        }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--val-border);
        }

        /* ===== FORM ===== */
        form {
            background: rgba(26, 39, 51, 0.7);
            border: 1px solid var(--val-border);
            clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 0 100%);
            padding: 28px 32px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            margin-bottom: 36px;
        }

        form input {
            background: rgba(15, 25, 35, 0.8);
            border: 1px solid rgba(255, 70, 85, 0.25);
            border-bottom: 1px solid rgba(255, 70, 85, 0.25) !important;
            color: var(--val-white);
            font-family: 'Barlow', sans-serif;
            font-size: 0.9rem;
            padding: 10px 14px;
            outline: none;
            transition: border-color 0.2s;
            width: 100%;
            box-shadow: none !important;
            height: auto !important;
        }

        form input::placeholder {
            color: rgba(236, 232, 225, 0.3);
            font-size: 0.85rem;
            letter-spacing: 1px;
        }

        form input:focus {
            border-color: var(--val-red) !important;
            box-shadow: none !important;
        }

        form input[name="title"],
        form input[name="content"] {
            grid-column: 1 / -1;
        }

        form button[type="submit"] {
            grid-column: 1 / -1;
            background: transparent;
            border: 2px solid var(--val-red);
            color: var(--val-white);
            font-family: 'Rajdhani', sans-serif;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            padding: 12px 0;
            cursor: pointer;
            clip-path: polygon(14px 0%, 100% 0%, calc(100% - 14px) 100%, 0% 100%);
            position: relative;
            overflow: hidden;
            transition: box-shadow 0.25s;
        }

        form button[type="submit"]::before {
            content: '';
            position: absolute;
            inset: 0;
            background: var(--val-red);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.28s ease;
            z-index: 0;
        }

        form button[type="submit"]:hover::before {
            transform: scaleX(1);
        }

        form button[type="submit"]:hover {
            box-shadow: 0 0 28px rgba(255, 70, 85, 0.4);
        }

        form button[type="submit"] span {
            position: relative;
            z-index: 1;
        }

        /* ===== CONTAINER ===== */
        .container {
            padding-top: 8px;
            padding-bottom: 40px;
        }

        h4 {
            display: none;
        }

        /* reemplazado por section-label */

        /* ===== CARDS ===== */
        .card {
            background: rgba(26, 39, 51, 0.75) !important;
            border: 1px solid var(--val-border) !important;
            clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
            box-shadow: none !important;
            border-radius: 0 !important;
            transition: border-color 0.25s, box-shadow 0.25s;
            overflow: hidden;
            animation: fadeUp 0.5s ease both;
        }

        .card:hover {
            border-color: var(--val-red) !important;
            box-shadow: 0 0 24px rgba(255, 70, 85, 0.15) !important;
        }

        .card-image {
            position: relative;
        }

        .card-image img {
            filter: brightness(0.8) saturate(0.7);
            transition: filter 0.3s;
            display: block;
            width: 100%;
        }

        .card:hover .card-image img {
            filter: brightness(0.95) saturate(1);
        }

        .card-image::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, transparent 40%, rgba(15, 25, 35, 0.85));
            pointer-events: none;
        }

        /* Corner accent */
        .card-image::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 16px;
            height: 16px;
            background: var(--val-red);
            clip-path: polygon(0 0, 100% 0, 100% 100%);
            z-index: 1;
        }

        .card-content {
            background: transparent !important;
            padding: 16px !important;
        }

        .card-title {
            font-family: 'Rajdhani', sans-serif !important;
            font-size: 1.1rem !important;
            font-weight: 700 !important;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--val-white) !important;
            display: block;
            margin-bottom: 8px;
        }

        .card-content p {
            font-size: 0.82rem;
            color: rgba(236, 232, 225, 0.55);
            line-height: 1.5;
            margin-bottom: 12px;
        }

        .card-content strong {
            color: rgba(236, 232, 225, 0.5);
            font-size: 0.75rem;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* Chips */
        .chip {
            background: rgba(255, 70, 85, 0.12) !important;
            border: 1px solid rgba(255, 70, 85, 0.3) !important;
            color: var(--val-red) !important;
            font-size: 0.7rem !important;
            letter-spacing: 1px;
            padding: 3px 8px !important;
            clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);
            border-radius: 0 !important;
            height: auto !important;
            line-height: 1.6 !important;
        }

        /* Card action */
        .card-action {
            background: transparent !important;
            border-top: 1px solid rgba(255, 70, 85, 0.12) !important;
            padding: 10px 16px !important;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-action span {
            font-size: 0.75rem;
            color: rgba(236, 232, 225, 0.45);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .card-action span strong {
            color: rgba(236, 232, 225, 0.8);
        }

        .card-action .right {
            display: flex;
            gap: 4px;
        }

        .btn-flat {
            padding: 6px !important;
            border: 1px solid transparent;
            transition: border-color 0.2s, background 0.2s;
        }

        .btn-flat:hover {
            background: rgba(255, 70, 85, 0.1) !important;
            border-color: rgba(255, 70, 85, 0.4);
        }

        .btn-flat .teal-text {
            color: var(--val-red) !important;
        }

        .btn-flat .red-text {
            color: rgba(255, 70, 85, 0.6) !important;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        @keyframes blink {

            0%,
            100% {
                opacity: 1
            }

            50% {
                opacity: .3
            }
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav>
        <div class="nav-wrapper teal">
            <a href="#!" class="brand-logo center">Social <em>Media</em></a>
        </div>
    </nav>

    <div class="container">

        <!-- Formulario -->
        <div class="section-label"><span>Nuevo Post</span></div>

        <form action="/posts/create" method="POST">
            <input type="text" name="title" placeholder="Título" required>
            <input type="text" name="content" placeholder="Contenido (mínimo 10 caracteres)" required>
            <input type="text" name="imageUrl" placeholder="URL Imagen">
            <input type="text" name="hashtags" placeholder="Hashtags separados por coma">
            <button type="submit"><span>Crear Post</span></button>
        </form>

        <!-- Posts -->
        <div class="section-label"><span>Posts</span></div>

        <div class="row">
            <% if (posts && posts.length> 0) { %>
                <% posts.forEach(post=> { %>
                    <div class="col s12 m6 l4">
                        <div class="card">
                            <div class="card-image">
                                <img src="<%= post.imageUrl || 'https://via.placeholder.com/400x300?text=No+Image' %>"
                                    alt="Imagen del post">
                            </div>
                            <div class="card-content">
                                <span class="card-title">
                                    <%= post.title %>
                                </span>
                                <p>
                                    <%= post.content %>
                                </p>
                                <p>
                                    <strong>Hashtags:</strong>
                                    <% if (post.hashtags && post.hashtags.length> 0) { %>
                                        <% post.hashtags.forEach(tag=> { %>
                                            <span class="chip">#<%= tag %></span>
                                            <% }) %>
                                                <% } else { %>
                                                    <span style="color: grey; font-size: 0.7rem;">Sin etiquetas</span>
                                                    <% } %>
                                </p>
                            </div>
                            <div class="card-action">
                                <span><strong>Sistema</strong></span>
                                <div class="right">
                                    <a href="/posts/edit/<%= post._id %>" class="btn-flat"><i
                                            class="material-icons teal-text">edit</i></a>
                                    <a href="/posts/delete/<%= post._id %>" class="btn-flat"
                                        onclick="return confirm('¿Eliminar?')">
                                        <i class="material-icons red-text">delete</i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="col s12">
                                <p class="center-align" style="color: var(--val-red); letter-spacing: 2px;">NO HAY POSTS
                                    DISPONIBLES</p>
                            </div>
                            <% } %>
        </div>

    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>

</html>